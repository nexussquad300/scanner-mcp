          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "MEDIUM",
          "finding_if_fail": "Cost Governance using old version (< v1.1)",
          "recommendation": "Update to Cost Governance Addendum v1.1 (includes Rule 5B payload cap)"
        },
        {
          "rule_id": "4.5",
          "check": "No autonomous recursive fixing rule",
          "field_path": "workspace/SOUL.md",
          "condition": "file_contains",
          "search_terms": ["no recursive", "Rule 4", "spawn", "sub-agent"],
