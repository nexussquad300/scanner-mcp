          "score_if_fail": 0,
          "severity": "MEDIUM",
          "finding_if_fail": "No explicit prohibition on recursive sub-agent spawning",
          "recommendation": "Add Rule 4 (no autonomous recursive fixing) to SOUL.md"
        }
      ],
      "max_score": 10,
      "score_calculation": "sum of rule scores, capped at max_score"
    },
    {
