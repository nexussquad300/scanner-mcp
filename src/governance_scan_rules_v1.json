          "recommendation": "Add COR-COST-001 reference to agent MEMORY.md"
        },
        {
          "rule_id": "4.2",
          "check": "Max retries rule enforced (Rule 1)",
          "field_path": "workspace/SOUL.md",
          "condition": "file_contains",
