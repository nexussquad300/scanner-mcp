          "score_if_fail": 1,
          "severity": "HIGH",
          "finding_if_fail": "25K token halt rule not documented",
          "recommendation": "Add Rule 5 (25K token halt) to SOUL.md"
        },
        {
          "rule_id": "4.4",
          "check": "Cost Governance Addendum v1.1 is current",
          "field_path": "workspace/MEMORY.md",
