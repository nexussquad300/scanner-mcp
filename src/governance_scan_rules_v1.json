{
  "metadata": {
    "version": "1.0",
    "source": "Warren (Ring 0, Systems Audit)",
    "purpose": "Deterministic agent infrastructure governance scan rules",
    "evaluation_method": "JSON/string inspection only, no LLM required",
    "total_categories": 10,
    "total_rules": 51,
    "date_created": "2026-04-01",
    "authority": "Warren governance audit protocol (v2.1 runsheet)"
  },
  "categories": [
    {
      "category_id": 1,
      "category_name": "Identity & Charter",
      "description": "Does the agent have a defined scope, name, role, and charter?",
      "rules": [
        {
          "rule_id": "1.1",
          "check": "Agent has unique name",
          "field_path": "name",
          "condition": "exists_and_non_empty",
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "FAIL",
          "finding_if_fail": "Agent name undefined or empty",
          "recommendation": "Add 'name' field to agent configuration"
        },
        {
          "rule_id": "1.2",
          "check": "Agent has defined role/ring",
          "field_path": "ring",
          "condition": "exists_and_in_list",
          "valid_values": ["Ring 0", "Ring 1", "Ring 2", "Ring 3"],
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "FAIL",
          "finding_if_fail": "Agent ring/role undefined",
          "recommendation": "Define ring assignment (0=core, 1=platform, 2=strategy, 3=specialized)"
        },
        {
          "rule_id": "1.3",
          "check": "Agent has SOUL.md or charter file",
          "field_path": "workspace",
          "condition": "file_exists",
          "file_path_pattern": "*/SOUL.md",
          "score_if_pass": 3,
          "score_if_fail": 1,
          "severity": "HIGH",
          "finding_if_fail": "Agent charter (SOUL.md) not found",
          "recommendation": "Create SOUL.md in agent workspace with purpose, rules, authority scope"
        },
        {
          "rule_id": "1.4",
          "check": "Charter contains authority scope",
          "field_path": "workspace/SOUL.md",
          "condition": "file_contains",
          "search_terms": ["Authority", "authority", "AUTHORITY"],
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "MEDIUM",
          "finding_if_fail": "Charter does not document authority boundaries",
          "recommendation": "Add 'AUTHORITY' section to SOUL.md defining what agent can and cannot do"
        },
        {
          "rule_id": "1.5",
          "check": "Agent purpose is documented",
          "field_path": "workspace/SOUL.md",
          "condition": "file_contains",
          "search_terms": ["Purpose", "purpose", "PURPOSE", "CORE PURPOSE"],
          "score_if_pass": 1,
          "score_if_fail": 0,
          "severity": "LOW",
          "finding_if_fail": "Agent purpose not documented",
          "recommendation": "Document core purpose at top of SOUL.md"
        }
      ],
      "max_score": 10,
      "score_calculation": "sum of rule scores, capped at max_score"
    },
    {
      "category_id": 2,
      "category_name": "Model Assignment",
      "description": "Is the agent assigned a valid LLM model with appropriate parameters?",
      "rules": [
        {
          "rule_id": "2.1",
          "check": "Agent has primary model assigned",
          "field_path": "agents.defaults.model.primary",
          "condition": "exists_and_non_empty",
          "score_if_pass": 3,
          "score_if_fail": 0,
          "severity": "FAIL",
          "finding_if_fail": "Agent has no primary model assigned",
          "recommendation": "Assign primary model in openclaw.json (e.g., anthropic/claude-sonnet-4-5-20250929)"
        },
        {
          "rule_id": "2.2",
          "check": "Model is in supported list",
          "field_path": "agents.defaults.model.primary",
          "condition": "exists_and_in_list",
          "valid_values": [
            "anthropic/claude-sonnet-4-5-20250929",
            "anthropic/claude-opus-4-1-20250805",
            "anthropic/claude-opus-4-6",
            "anthropic/claude-haiku-4-5-20251001",
            "openai/gpt-4-turbo",
            "google/gemini-2.0-flash"
          ],
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "HIGH",
          "finding_if_fail": "Model not in supported provider list",
          "recommendation": "Use approved model from openclaw.json models section"
        },
        {
          "rule_id": "2.3",
          "check": "Model has cache retention policy",
          "field_path": "agents.defaults.models.[model].params.cacheRetention",
          "condition": "exists_and_in_list",
          "valid_values": ["short", "long"],
          "score_if_pass": 2,
          "score_if_fail": 1,
          "severity": "MEDIUM",
          "finding_if_fail": "Cache retention policy undefined",
          "recommendation": "Set cacheRetention to 'long' for cost-efficient multi-session agents"
        },
        {
          "rule_id": "2.4",
          "check": "Ring 0 agents use minimal thinking",
          "field_path": "agents.defaults.models.[model].params.thinking",
          "condition": "ring_0_has_low_thinking",
          "max_thinking_value": "low",
          "score_if_pass": 2,
          "score_if_fail": 1,
          "severity": "MEDIUM",
          "finding_if_fail": "Ring 0 agent has high thinking overhead",
          "recommendation": "Set thinking='low' for Ring 0 auditing agents (Warren, Vale, Nexus)"
        },
        {
          "rule_id": "2.5",
          "check": "Model context window is sufficient",
          "field_path": "agents.defaults.model.primary",
          "condition": "model_context_200k",
          "score_if_pass": 1,
          "score_if_fail": 0,
          "severity": "LOW",
          "finding_if_fail": "Model context window may be insufficient (< 200K)",
          "recommendation": "Consider upgrading to model with 200K+ context window for long governance sessions"
        }
      ],
      "max_score": 10,
      "score_calculation": "sum of rule scores, capped at max_score"
    },
    {
      "category_id": 3,
      "category_name": "Permission Boundaries",
      "description": "Are tool permissions correctly scoped per agent role?",
      "rules": [
        {
          "rule_id": "3.1",
          "check": "Agent sandbox mode defined",
          "field_path": "agents.[agent_name].sandbox",
          "condition": "exists_and_in_list",
          "valid_values": ["inherit", "require"],
          "score_if_pass": 3,
          "score_if_fail": 0,
          "severity": "FAIL",
          "finding_if_fail": "Sandbox mode not defined",
          "recommendation": "Set sandbox to 'inherit' (for main sessions) or 'require' (for isolated crons)"
        },
        {
          "rule_id": "3.2",
          "check": "Elevated tools disabled by default",
          "field_path": "elevated.enabled",
          "condition": "equals_false",
          "score_if_pass": 3,
          "score_if_fail": 0,
          "severity": "CRITICAL",
          "finding_if_fail": "Elevated tools (exec, shell, code) globally enabled",
          "recommendation": "Set elevated.enabled = false in openclaw.json (default deny)"
        },
        {
          "rule_id": "3.3",
          "check": "Agent-to-agent auth enabled",
          "field_path": "agentToAgent.enabled",
          "condition": "equals_true",
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "HIGH",
          "finding_if_fail": "Agent-to-agent routing disabled",
          "recommendation": "Enable agentToAgent.enabled = true for multi-agent coordination"
        },
        {
          "rule_id": "3.4",
          "check": "Tool deny list is non-empty",
          "field_path": "tools.deny",
          "condition": "exists_and_non_empty",
          "score_if_pass": 2,
          "score_if_fail": 1,
          "severity": "MEDIUM",
          "finding_if_fail": "No default tool deny list",
          "recommendation": "Add tools.deny = ['group:runtime', 'group:ui'] at minimum"
        },
        {
          "rule_id": "3.5",
          "check": "Ring boundaries respected",
          "field_path": "ring",
          "condition": "tool_access_matches_ring",
          "ring_0_tools": ["sessions_list", "sessions_history", "memory_search", "message"],
          "ring_1_tools": ["read", "write", "edit", "web_search"],
          "ring_2_tools": ["web_fetch", "pdf"],
          "ring_3_tools": ["image_generate", "tts"],
          "score_if_pass": 2,
          "score_if_fail": 0,
          "severity": "MEDIUM",
          "finding_if_fail": "Agent tool access violates ring boundaries",
          "recommendation": "Verify agent tools match ring assignment"
        }
      ],
      "max_score": 10,
      "score_calculation": "sum of rule scores, capped at max_score"
    },
    {
